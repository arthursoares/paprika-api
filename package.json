{
  "name": "paprika-api",
  "version": "2.0.0",
  "description": "Unofficial Node.js client for Paprika Recipe Manager",
  "author": "Arthur Soares",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arthursoares/paprika-api.git"
  },
  "bugs": {
    "url": "https://github.com/arthursoares/paprika-api/issues"
  },
  "homepage": "https://github.com/arthursoares/paprika-api#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "paprika": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "paprika",
    "recipe",
    "api",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.2.3",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "zod": "^3.22.0"
  }
}
